<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.4" snapToGrid="true">
  <code><![CDATA[
; ============================================================================
; Hormuz Escalation ABM  (v1.88, Conference)
; ============================================================================

breed [state-actors state-actor]
breed [mines mine]

patches-own [
  water?
  lane?
  blocked?
  reachable?
]

state-actors-own [
  role
  current-action

  risk-tolerance
  electoral-proximity
  belief-iran-bluffing

  regime-stability
  asymmetric-assets
  economic-buffer
  belief-us-will-invade

  security-perception
  tolerance-us-friction
]

globals [

  physical-throughput
  commercial-throughput
  navigational-reliability
  permission-factor
  insurance-availability
  operator-caution
  port-operability
  anchorage-risk
  gnss-reliability
  recovery-factor
  strait-throughput
  brent-crude-price
  market-panic-index
  military-degradation
  us-casualties
  regional-strike-volume
  proxy-attack-level

  ceasefire?
  ground-war?
  accidental-war?
  crisis-state
  deadline-remaining
  equilibrium-pain-streak
  cascade-streak
  ceasefire-stability-streak
  partial-closure-streak
  selective-passage-streak
  contested-reopening-streak
  cumulative-oil-burden
  low-throughput-days
  recent-iran-escalation-streak
  diplomatic-momentum
  misperception-count
  resolution-tick

  military-pause?
  economic-war-active?
  military-state
  economic-war-state
  access-state
  diplomacy-state
  insurer-memory
  operator-memory
  market-memory
  israel-incomplete-victory-aversion

  last-us-action
  last-iran-action
  last-israel-action

  us-observed-iran-action
  iran-observed-us-action
  israel-observed-iran-action
  israel-observed-us-action

  ticks-in-selective-passage
  ticks-in-contested-reopening
  ticks-in-partial-closure
  ever-selective-passage?
  ever-contested-reopening?
  ever-partial-closure?

  disruption-prior
  disruption-posterior
  awrp
  awrp-baseline
  awrp-peak

  oil-fundamental-price
  oil-risk-premium
  risk-premium-peak

  tick-military-pause-start
  tick-military-pause-window-start
  tick-military-deescalation-window-start
  tick-awrp-recovery
  tick-price-recovery

  managed-stalemate?
  managed-stalemate-streak
  ever-managed-stalemate?

  tau-m-rate

  recent-strike-history
  recent-major-strike-history
  military-pause-window?
  military-deescalation-window?
  major-action-this-tick?
  low-intensity-military?
  commercial-non-normalization-score
  ticks-in-ms-conditions
  awrp-recovery-frac-fired?
  price-recovery-frac-fired?
  tick-awrp-recovery-frac
  tick-price-recovery-frac

  ticks-since-major-strike
  price-recovery-frac-strict-fired?
  tick-price-recovery-frac-strict

  market-shock-build-up-rate
  market-recovery-rate-current
  risk-premium-gross-signal
  risk-premium-reassurance-signal
  risk-premium-target
  risk-premium-gap
  risk-premium-post-peak-ticks
  risk-premium-decay-ticks
  risk-premium-post-deescalation-ticks
  risk-premium-post-deescalation-decay-ticks
  price-recovery-20pct-fired?
  tick-price-recovery-20pct
  tick-first-managed-stalemate

  diplomacy-bridge-events
  ever-backchannel?
  ever-ceasefire-talks?
  ever-fragile-arrangement?
  first-backchannel-tick
  first-ceasefire-talks-tick
  first-fragile-arrangement-tick
  ticks-in-no-talks
  ticks-in-backchannel
  ticks-in-ceasefire-talks
  ticks-in-fragile-arrangement
  max-diplomatic-momentum
]

to setup
  clear-all
  setup-parameters
  setup-geography
  setup-actors
  setup-initial-mines

  set ticks-in-selective-passage 0
  set ticks-in-contested-reopening 0
  set ticks-in-partial-closure 0

  set ever-selective-passage? false
  set ever-contested-reopening? false
  set ever-partial-closure? false

  update-market-state
  reset-ticks
end

to setup-parameters

  set military-degradation 0.15
  set us-casualties 0
  set regional-strike-volume 0
  set proxy-attack-level 0

  set physical-throughput 0
  set commercial-throughput 0.35
  set navigational-reliability 0.45
  set permission-factor 0.35
  set insurance-availability 0.30
  set operator-caution 0.75
  set port-operability 0.70
  set anchorage-risk 0.55
  set gnss-reliability 0.45
  set recovery-factor 0.45
  set strait-throughput 0
  set brent-crude-price 70
  set market-panic-index 0

  set ceasefire? false
  set ground-war? false
  set accidental-war? false
  set crisis-state "Armed_Bargaining"

  set deadline-remaining 7
  set equilibrium-pain-streak 0
  set cascade-streak 0
  set ceasefire-stability-streak 0
  set partial-closure-streak 0
  set selective-passage-streak 0
  set contested-reopening-streak 0
  set cumulative-oil-burden 0
  set low-throughput-days 0
  set recent-iran-escalation-streak 0
  set diplomatic-momentum 0
  set misperception-count 0
  set resolution-tick -1

  set military-pause? false
  set economic-war-active? true
  set military-state "Limited_Exchange"
  set economic-war-state "Oil_Price_Coercion"
  set access-state "Selective_Passage"

  set diplomacy-state "No_Talks"

  set insurer-memory initial-insurer-memory
  set operator-memory initial-operator-memory
  set market-memory initial-market-memory
  set israel-incomplete-victory-aversion initial-israel-incomplete-victory-aversion

  set last-us-action "None"
  set last-iran-action "None"
  set last-israel-action "None"
  set us-observed-iran-action "None"
  set iran-observed-us-action "None"
  set israel-observed-iran-action "None"
  set israel-observed-us-action "None"

  set disruption-prior 0.20
  set disruption-posterior 0.55
  set awrp-baseline 0.20
  set awrp 0.55
  set awrp-peak 0.55

  set oil-fundamental-price 70
  set oil-risk-premium 0
  set risk-premium-peak 0

  set tick-military-pause-start -1
  set tick-military-pause-window-start -1
  set tick-military-deescalation-window-start -1
  set tick-awrp-recovery -1
  set tick-price-recovery -1

  set managed-stalemate? false
  set managed-stalemate-streak 0
  set ever-managed-stalemate? false
  set tau-m-rate 1.0

  set recent-strike-history (list 0 0 0)
  set recent-major-strike-history (list 0 0 0)
  set military-pause-window? false
  set military-deescalation-window? false
  set major-action-this-tick? false
  set low-intensity-military? false
  set commercial-non-normalization-score 0
  set ticks-in-ms-conditions 0
  set awrp-recovery-frac-fired? false
  set price-recovery-frac-fired? false
  set tick-awrp-recovery-frac -1
  set tick-price-recovery-frac -1

  set ticks-since-major-strike 0
  set price-recovery-frac-strict-fired? false
  set tick-price-recovery-frac-strict -1

  set market-shock-build-up-rate 0.25
  set market-recovery-rate-current 0
  set risk-premium-gross-signal 0
  set risk-premium-reassurance-signal 0
  set risk-premium-target 0
  set risk-premium-gap 0
  set risk-premium-post-peak-ticks 0
  set risk-premium-decay-ticks 0
  set risk-premium-post-deescalation-ticks 0
  set risk-premium-post-deescalation-decay-ticks 0
  set price-recovery-20pct-fired? false
  set tick-price-recovery-20pct -1
  set tick-first-managed-stalemate -1

  set diplomacy-bridge-events 0
  set ever-backchannel? false
  set ever-ceasefire-talks? false
  set ever-fragile-arrangement? false
  set first-backchannel-tick -1
  set first-ceasefire-talks-tick -1
  set first-fragile-arrangement-tick -1
  set ticks-in-no-talks 0
  set ticks-in-backchannel 0
  set ticks-in-ceasefire-talks 0
  set ticks-in-fragile-arrangement 0
  set max-diplomatic-momentum diplomatic-momentum
end

to setup-geography
  ask patches [
    set water? false
    set lane? false
    set blocked? false
    set reachable? false

    if abs pycor <= 4 [ set water? true ]
    if abs pycor <= 2 [ set lane? true ]

    recolor-patch
  ]
end

to recolor-patch
  ifelse water?
  [
    ifelse lane?
      [ set pcolor 87 ]
      [ set pcolor 95 ]
  ]
  [ set pcolor 35 ]
end

to setup-actors
  set-default-shape state-actors "person"

  create-state-actors 1 [
    set role "US"
    set color blue
    set size 2
    setxy (min-pxcor + 3) (max-pycor - 2)
    set label "US"
    set label-color white

    set risk-tolerance 0.33
    set electoral-proximity 0.78
    set belief-iran-bluffing 0.40

    set regime-stability 0
    set asymmetric-assets 0
    set economic-buffer 0
    set belief-us-will-invade 0
    set security-perception 0
    set tolerance-us-friction 0
    set current-action "Hold"
  ]

  create-state-actors 1 [
    set role "Iran"
    set color red
    set size 2
    setxy 0 (max-pycor - 2)
    set label "Iran"
    set label-color white

    set risk-tolerance 0
    set electoral-proximity 0
    set belief-iran-bluffing 0

    set regime-stability initial-iran-regime-stability
    set asymmetric-assets initial-iran-assets
    set economic-buffer 0.35
    set belief-us-will-invade 0.20

    set security-perception 0
    set tolerance-us-friction 0
    set current-action "Hold"
  ]

  create-state-actors 1 [
    set role "Israel"
    set color yellow
    set size 2
    setxy (max-pxcor - 3) (max-pycor - 2)
    set label "Israel"
    set label-color white

    set risk-tolerance 0
    set electoral-proximity 0
    set belief-iran-bluffing 0
    set regime-stability 0
    set asymmetric-assets 0
    set economic-buffer 0
    set belief-us-will-invade 0

    set security-perception initial-israel-security-perception
    set tolerance-us-friction initial-israel-friction
    set current-action "Hold"
  ]
end

to setup-initial-mines
  set-default-shape mines "circle"
  let open-lanes patches with [ lane? ]
  if any? open-lanes [
    ask n-of (min (list initial-mine-count (count open-lanes))) open-lanes [
      sprout-mines 1 [
        set color red + 2
        set size 0.8
      ]
    ]
  ]
end

to go
  if ticks >= max-ticks [
    finalize-timeout-state
    stop
  ]
  if ceasefire? or ground-war? [ stop ]

  observe-and-update-beliefs
  decide-actions
  execute-actions
  update-market-state
  update-clock-trackers
  determine-crisis-state
  update-actor-states
  update-state-counters

  set deadline-remaining max (list 0 (deadline-remaining - 1))
  tick
end

to update-state-counters
  if access-state = "Selective_Passage" [
    set ticks-in-selective-passage ticks-in-selective-passage + 1
    set ever-selective-passage? true
  ]

  if (crisis-state = "Contested_Reopening") or (access-state = "Escorted_Reopening") [
    set ticks-in-contested-reopening ticks-in-contested-reopening + 1
    set ever-contested-reopening? true
  ]

  if access-state = "Partial_Closure" [
    set ticks-in-partial-closure ticks-in-partial-closure + 1
    set ever-partial-closure? true
  ]

  set max-diplomatic-momentum (max list max-diplomatic-momentum diplomatic-momentum)

  if diplomacy-state = "No_Talks" [
    set ticks-in-no-talks (ticks-in-no-talks + 1)
  ]
  if diplomacy-state = "Backchannel_Bargaining" [
    set ticks-in-backchannel (ticks-in-backchannel + 1)
  ]
  if diplomacy-state = "Ceasefire_Talks" [
    set ticks-in-ceasefire-talks (ticks-in-ceasefire-talks + 1)
  ]
  if diplomacy-state = "Fragile_Arrangement" [
    set ticks-in-fragile-arrangement (ticks-in-fragile-arrangement + 1)
  ]

  if member? diplomacy-state ["Backchannel_Bargaining" "Ceasefire_Talks" "Fragile_Arrangement"] [
    set ever-backchannel? true
    if first-backchannel-tick = -1 [ set first-backchannel-tick ticks ]
  ]
  if member? diplomacy-state ["Ceasefire_Talks" "Fragile_Arrangement"] [
    set ever-ceasefire-talks? true
    if first-ceasefire-talks-tick = -1 [ set first-ceasefire-talks-tick ticks ]
  ]
  if diplomacy-state = "Fragile_Arrangement" [
    set ever-fragile-arrangement? true
    if first-fragile-arrangement-tick = -1 [ set first-fragile-arrangement-tick ticks ]
  ]

  ifelse major-action-this-tick?
    [ set ticks-since-major-strike 0 ]
    [ set ticks-since-major-strike (ticks-since-major-strike + 1) ]
end

to observe-and-update-beliefs
  set us-observed-iran-action (perceived-action last-iran-action "Iran")
  set iran-observed-us-action (perceived-action last-us-action "US")
  set israel-observed-iran-action (perceived-action last-iran-action "Iran")
  set israel-observed-us-action (perceived-action last-us-action "US")

  if us-observed-iran-action != last-iran-action and last-iran-action != "None" [ set misperception-count (misperception-count + 1) ]
  if iran-observed-us-action != last-us-action and last-us-action != "None" [ set misperception-count (misperception-count + 1) ]
  if israel-observed-iran-action != last-iran-action and last-iran-action != "None" [ set misperception-count (misperception-count + 1) ]
  if israel-observed-us-action != last-us-action and last-us-action != "None" [ set misperception-count (misperception-count + 1) ]

  if us-observed-iran-action = "Deploy_Mines" [
    ask us-agent [ set belief-iran-bluffing (bayes-update belief-iran-bluffing 0.15 0.85) ]
  ]
  if us-observed-iran-action = "Selective_Passage" [
    ask us-agent [ set belief-iran-bluffing (bayes-update belief-iran-bluffing 0.55 0.45) ]
  ]
  if us-observed-iran-action = "Conditional_Reopening" [
    ask us-agent [ set belief-iran-bluffing (bayes-update belief-iran-bluffing 0.62 0.32) ]
  ]
  if us-observed-iran-action = "Sustain_Economic_War" [
    ask us-agent [ set belief-iran-bluffing (bayes-update belief-iran-bluffing 0.25 0.72) ]
  ]
  if us-observed-iran-action = "Missile_Swarm" [
    ask us-agent [ set belief-iran-bluffing (bayes-update belief-iran-bluffing 0.10 0.80) ]
  ]
  if us-observed-iran-action = "Harass_Shipping" [
    ask us-agent [ set belief-iran-bluffing (bayes-update belief-iran-bluffing 0.18 0.78) ]
  ]
  if us-observed-iran-action = "Proxy_Attack" [
    ask us-agent [ set belief-iran-bluffing (bayes-update belief-iran-bluffing 0.20 0.75) ]
  ]

  if iran-observed-us-action = "Deploy_Carrier_Group" [
    ask iran-agent [ set belief-us-will-invade (bayes-update belief-us-will-invade 0.90 0.40) ]
  ]
  if iran-observed-us-action = "Ground_Operation" [
    ask iran-agent [ set belief-us-will-invade (bayes-update belief-us-will-invade 0.95 0.10) ]
  ]
  if iran-observed-us-action = "Conventional_Strike" [
    ask iran-agent [ set belief-us-will-invade (bayes-update belief-us-will-invade 0.70 0.45) ]
  ]
  if iran-observed-us-action = "Pursue_Ceasefire" [
    ask iran-agent [ set belief-us-will-invade (bayes-update belief-us-will-invade 0.15 0.60) ]
  ]

  if israel-observed-iran-action = "Missile_Swarm" [
    ask israel-agent [ set security-perception (bound (security-perception - 0.05) 0 1) ]
  ]
  if israel-observed-iran-action = "Deploy_Mines" [
    ask israel-agent [ set security-perception (bound (security-perception - 0.03) 0 1) ]
  ]
  if israel-observed-iran-action = "Selective_Passage" [
    ask israel-agent [ set security-perception (bound (security-perception + 0.01) 0 1) ]
  ]
  if israel-observed-iran-action = "Conditional_Reopening" [
    ask israel-agent [ set security-perception (bound (security-perception + 0.02) 0 1) ]
  ]
  if israel-observed-iran-action = "Sustain_Economic_War" [
    ask israel-agent [ set security-perception (bound (security-perception - 0.03) 0 1) ]
  ]
  if israel-observed-iran-action = "Harass_Shipping" [
    ask israel-agent [ set security-perception (bound (security-perception - 0.04) 0 1) ]
  ]

  if israel-observed-us-action = "Pursue_Ceasefire" [
    ask israel-agent [
      if security-perception < 0.40 [
        set tolerance-us-friction (bound (tolerance-us-friction + 0.02) 0 1)
      ]
    ]
  ]
  if member? israel-observed-us-action ["Conventional_Strike" "Ground_Operation"] [
    ask israel-agent [ set tolerance-us-friction (bound (tolerance-us-friction - 0.01) 0 1) ]
  ]
end

to decide-actions
  decide-us-action
  decide-israel-action
  decide-iran-action
end

to decide-us-action
  let actions ["Pursue_Ceasefire" "Hold" "Deploy_Carrier_Group" "Conventional_Strike" "Ground_Operation"]
  let best-action "Hold"
  let best-u -999999

  foreach actions [ act ->
    let u (us-utility-of act)
    if u > best-u [
      set best-u u
      set best-action act
    ]
  ]
  ask us-agent [ set current-action best-action ]
end

to decide-israel-action
  let actions ["Hold" "Conventional_Strike" "Max_Strike" "Ground_Push"]
  let best-action "Hold"
  let best-u -999999

  foreach actions [ act ->
    let u (israel-utility-of act)
    if u > best-u [
      set best-u u
      set best-action act
    ]
  ]
  ask israel-agent [ set current-action best-action ]
end

to decide-iran-action
  let actions ["Conditional_Reopening" "Selective_Passage" "Sustain_Economic_War" "Hold" "Deploy_Mines" "Harass_Shipping" "Proxy_Attack" "Missile_Swarm"]
  let best-action "Hold"
  let best-u -999999

  foreach actions [ act ->
    let u (iran-utility-of act)
    if u > best-u [
      set best-u u
      set best-action act
    ]
  ]
  ask iran-agent [ set current-action best-action ]
end

to-report us-utility-of [act]
  let belief [belief-iran-bluffing] of us-agent
  let elect [electoral-proximity] of us-agent
  let risk [risk-tolerance] of us-agent

  let degradation 0
  let casualties 0
  let oil-impact 0

  if act = "Pursue_Ceasefire" [
    set degradation 0
    set casualties 0
    set oil-impact -18
  ]
  if act = "Hold" [
    set degradation 0.01
    set casualties 0.01
    set oil-impact 3
  ]
  if act = "Deploy_Carrier_Group" [
    set degradation 0.05
    set casualties 0.02
    set oil-impact 8
  ]
  if act = "Conventional_Strike" [
    set degradation (0.18 + (belief * 0.20))
    set casualties 0.05
    set oil-impact 15
  ]
  if act = "Ground_Operation" [
    set degradation 0.65
    set casualties 0.55
    set oil-impact 35
  ]

  let projected-oil (brent-crude-price + oil-impact)
  let political-cost ((projected-oil / 100) * elect)

  let alpha 0.40
  let beta 0.60
  let gamma 0.80
  let delta 0.90

  let u ((alpha * degradation)
       - (beta * (projected-oil / 150))
       - (gamma * casualties)
       - (delta * political-cost))

  if act = "Pursue_Ceasefire" [
    if projected-oil > 110 [ set u (u + 0.25) ]
    if belief < 0.20 [ set u (u + 0.10) ]
    if military-degradation > 0.35 [ set u (u + 0.10) ]
    if strait-throughput > 0.65 [ set u (u + 0.08) ]
    if strait-throughput < 0.35 [ set u (u - 0.25) ]
    if insurance-availability < 0.40 [ set u (u - 0.18) ]
    if permission-factor < 0.50 [ set u (u - 0.12) ]
    if recent-iran-escalation-streak > 0 [ set u (u - 0.12) ]
    set u (u + (diplomatic-momentum * 0.10))
  ]

  if act = "Ground_Operation" [

    if strait-throughput < 0.18 [ set u (u + 0.12) ]
    if us-casualties > 0.20 [ set u (u + 0.10) ]
    if deadline-remaining <= 2 and strait-throughput < 0.30 [ set u (u + 0.10) ]
    set u (u + (risk * 0.08))
    if military-deescalation-window? [ set u (u - 0.18) ]
    if elect > 0.85 [ set u (u - 0.20) ]
  ]

  if act = "Deploy_Carrier_Group" [
    if strait-throughput < 0.40 [ set u (u + 0.10) ]
  ]

  report (u + random-normal 0 decision-noise)
end

to-report iran-utility-of [act]
  let stability [regime-stability] of iran-agent
  let assets [asymmetric-assets] of iran-agent
  let buffer [economic-buffer] of iran-agent
  let invade-belief [belief-us-will-invade] of iran-agent

  let regime-survival stability
  let economic-leverage (((brent-crude-price - 70) / 100)
                         + ((1 - insurance-availability) * 0.35)
                         + ((1 - permission-factor) * 0.22)
                         + (market-memory * 0.25))
  let military-loss military-degradation
  let sovereignty-loss 0
  let asset-cost 0

  if act = "Conditional_Reopening" [
    set economic-leverage (economic-leverage + 0.06)
    set sovereignty-loss 0.05
  ]
  if act = "Selective_Passage" [
    set economic-leverage (economic-leverage + 0.10)
    set sovereignty-loss 0.03
  ]
  if act = "Sustain_Economic_War" [
    set economic-leverage (economic-leverage + 0.20)
    set sovereignty-loss 0.02
    set asset-cost 0.03
  ]
  if act = "Hold" [
    set economic-leverage (economic-leverage - 0.04)
  ]
  if act = "Deploy_Mines" [
    set economic-leverage (economic-leverage + 0.22)
    set sovereignty-loss 0.05
    set asset-cost 0.06
  ]
  if act = "Harass_Shipping" [
    set economic-leverage (economic-leverage + 0.17)
    set sovereignty-loss 0.03
    set asset-cost 0.05
  ]
  if act = "Proxy_Attack" [
    set economic-leverage (economic-leverage + 0.12)
    set sovereignty-loss 0.06
    set asset-cost 0.06
  ]
  if act = "Missile_Swarm" [
    set economic-leverage (economic-leverage + 0.18)
    set sovereignty-loss 0.10
    set asset-cost 0.12
  ]

  let zeta 1.15
  let eta 0.85
  let theta 0.70
  let kappa 0.95

  let u ((zeta * regime-survival)
       + (eta * economic-leverage)
       - (theta * military-loss)
       - (kappa * sovereignty-loss))

  if stability < 0.35 [
    let pressure ((0.35 - stability) / 0.35)
    if member? act ["Deploy_Mines" "Harass_Shipping" "Proxy_Attack" "Missile_Swarm"] [
      set u (u - (pressure * 0.35))
    ]
    if member? act ["Conditional_Reopening" "Selective_Passage"] [
      set u (u + (pressure * 0.35))
    ]
  ]

  if military-pause? and economic-war-active? [
    if act = "Sustain_Economic_War" [ set u (u + 0.18) ]
    if act = "Selective_Passage" [ set u (u + 0.08) ]
    if act = "Hold" [ set u (u - 0.15) ]
  ]

  if act = "Conditional_Reopening" [
    if diplomatic-momentum > 0.45 [ set u (u + 0.14) ]
    if buffer < 0.35 [ set u (u + 0.10) ]
    if invade-belief > 0.70 [ set u (u + 0.06) ]
  ]

  if act = "Selective_Passage" [
    if buffer < 0.35 [ set u (u + 0.18) ]
    if diplomatic-momentum > 0.40 [ set u (u + 0.06) ]
  ]

  if act = "Sustain_Economic_War" [
    if market-memory > 0.40 [ set u (u + 0.12) ]
    if brent-crude-price > 95 [ set u (u + 0.08) ]
    if assets < 15 [ set u (u - 0.08) ]
  ]

  if act = "Deploy_Mines" [
    if assets < 20 [ set u (u - 0.30) ]
    if invade-belief > 0.75 [ set u (u - 0.18) ]
  ]

  if act = "Harass_Shipping" [
    if assets < 20 [ set u (u - 0.18) ]
    if invade-belief > 0.80 [ set u (u - 0.08) ]
  ]

  if act = "Missile_Swarm" and military-pause? [
    set u (u - 0.20)
  ]

  report ((u - asset-cost) + random-normal 0 decision-noise)
end

to-report israel-utility-of [act]
  let sec [security-perception] of israel-agent
  let friction [tolerance-us-friction] of israel-agent
  let threat (1 - sec)

  let threat-reduction 0
  let us-friction-cost 0
  let escalation-risk 0

  if act = "Hold" [
    set threat-reduction 0.02
    set us-friction-cost 0
    set escalation-risk 0
  ]
  if act = "Conventional_Strike" [
    set threat-reduction 0.16
    set us-friction-cost 0.04
    set escalation-risk 0.08
  ]
  if act = "Max_Strike" [
    set threat-reduction 0.24
    set us-friction-cost 0.10
    set escalation-risk 0.16
  ]
  if act = "Ground_Push" [
    set threat-reduction 0.40
    set us-friction-cost 0.18
    set escalation-risk 0.25
  ]

  let omega 0.90
  let phi 0.55
  let psi 0.40

  let u ((omega * threat * threat-reduction)
       - (phi * (us-friction-cost * (1 - friction)))
       - (psi * escalation-risk))

  if act = "Max_Strike" and threat > 0.60 [ set u (u + 0.20) ]
  if act = "Ground_Push" and threat > 0.75 [ set u (u + 0.15) ]

  if last-us-action = "Pursue_Ceasefire" and act = "Max_Strike" [ set u (u + 0.05) ]
  if last-us-action = "Pursue_Ceasefire" and act = "Ground_Push" and threat > 0.70 [ set u (u + 0.10) ]
  if military-degradation > 0.60 and act = "Hold" [ set u (u + 0.12) ]

  if military-pause? and economic-war-active? [
    if act = "Hold" [ set u (u - (0.18 * israel-incomplete-victory-aversion)) ]
    if act = "Conventional_Strike" [ set u (u + (0.10 * israel-incomplete-victory-aversion)) ]
    if act = "Max_Strike" [ set u (u + (0.14 * israel-incomplete-victory-aversion)) ]

    if act = "Ground_Push" [ set u (u + (0.04 * israel-incomplete-victory-aversion)) ]
  ]

  if act = "Ground_Push" and diplomatic-momentum > 0.30 [
    set u (u - 0.12)
  ]

  if access-state = "Selective_Passage" and member? act ["Conventional_Strike" "Max_Strike"] [
    set u (u + 0.06)
  ]

  if act = "Ground_Push"
     and military-deescalation-window?
     and access-state = "Selective_Passage" [
    set u (u - 0.08)
  ]

  if access-state = "Escorted_Reopening" and act = "Hold" and economic-war-active? [
    set u (u - 0.05)
  ]

  if act = "Ground_Push" and ticks < 8 [ set u (u - 0.40) ]
  if act = "Max_Strike" and ticks < 4 [ set u (u - 0.15) ]

  report (u + random-normal 0 decision-noise)
end

to execute-actions
  set regional-strike-volume 0
  set proxy-attack-level 0

  set last-us-action [current-action] of us-agent
  set last-israel-action [current-action] of israel-agent
  set last-iran-action [current-action] of iran-agent

  execute-us-action last-us-action
  execute-israel-action last-israel-action
  execute-iran-action last-iran-action
end

to execute-us-action [act]
  if act = "Pursue_Ceasefire" [
    ask us-agent [ set electoral-proximity (bound (electoral-proximity + 0.005) 0 1) ]
  ]

  if act = "Deploy_Carrier_Group" [
    ask us-agent [ set electoral-proximity (bound (electoral-proximity + 0.004) 0 1) ]
    set regional-strike-volume (regional-strike-volume + 1)
    set military-degradation (bound (military-degradation + 0.03) 0 1)
  ]

  if act = "Conventional_Strike" [
    ask us-agent [ set electoral-proximity (bound (electoral-proximity + 0.004) 0 1) ]
    set regional-strike-volume (regional-strike-volume + 2)
    set military-degradation (bound (military-degradation + 0.10) 0 1)
    set us-casualties (bound (us-casualties + 0.03) 0 1)
    ask iran-agent [
      set regime-stability (bound (regime-stability - 0.08) 0 1)
      set asymmetric-assets (bound (asymmetric-assets - 8) 0 100)
    ]
  ]

  if act = "Ground_Operation" [
    set regional-strike-volume (regional-strike-volume + 3)
    set military-degradation (bound (military-degradation + 0.28) 0 1)
    set us-casualties (bound (us-casualties + 0.18) 0 1)
    ask iran-agent [
      set regime-stability (bound (regime-stability - 0.18) 0 1)
      set asymmetric-assets (bound (asymmetric-assets - 15) 0 100)
    ]
    set ground-war? true
  ]
end

to execute-israel-action [act]
  if act = "Conventional_Strike" [
    set regional-strike-volume (regional-strike-volume + 1)
    set military-degradation (bound (military-degradation + 0.08) 0 1)
    ask iran-agent [
      set regime-stability (bound (regime-stability - 0.05) 0 1)
      set asymmetric-assets (bound (asymmetric-assets - 6) 0 100)
    ]
  ]

  if act = "Max_Strike" [
    set regional-strike-volume (regional-strike-volume + 2)
    set military-degradation (bound (military-degradation + 0.15) 0 1)
    ask iran-agent [
      set regime-stability (bound (regime-stability - 0.12) 0 1)
      set asymmetric-assets (bound (asymmetric-assets - 12) 0 100)
    ]
    ask us-agent [ set electoral-proximity (bound (electoral-proximity + 0.05) 0 1) ]
  ]

  if act = "Ground_Push" [
    set regional-strike-volume (regional-strike-volume + 3)
    set military-degradation (bound (military-degradation + 0.25) 0 1)
    ask iran-agent [
      set regime-stability (bound (regime-stability - 0.20) 0 1)
      set asymmetric-assets (bound (asymmetric-assets - 15) 0 100)
    ]
    set us-casualties (bound (us-casualties + 0.10) 0 1)
    set ground-war? true

    if last-us-action != "Ground_Operation" [
      let miscoord-risk (0.10 + (0.30 * decision-noise) + (0.15 * observation-error-rate))
      if member? last-us-action ["Pursue_Ceasefire" "Hold"] [ set miscoord-risk (miscoord-risk + 0.12) ]
      if last-us-action = "Deploy_Carrier_Group" [ set miscoord-risk (miscoord-risk + 0.06) ]
      if diplomatic-momentum > 0.40 [ set miscoord-risk (miscoord-risk - 0.12) ]
      if [security-perception] of israel-agent < 0.30 [ set miscoord-risk (miscoord-risk + 0.06) ]
      if (random-float 1) < (bound miscoord-risk 0.03 0.65) [ set accidental-war? true ]
    ]
  ]
end

to execute-iran-action [act]
  if act = "Conditional_Reopening" [
    if any? mines [
      ask n-of (min (list 1 (count mines))) mines [ die ]
    ]
    set permission-factor (bound (permission-factor + 0.14) 0.10 0.98)
    set insurance-availability (bound (insurance-availability + 0.05) 0.10 1)
    set gnss-reliability (bound (gnss-reliability + 0.03) 0.15 1)
    set operator-caution (bound (operator-caution - 0.04) 0 1)
    set insurer-memory (bound (insurer-memory - 0.03) 0 1)
    set market-memory (bound (market-memory - 0.03) 0 1)
    ask iran-agent [
      set economic-buffer (bound (economic-buffer + 0.01) 0 1)
    ]
  ]

  if act = "Selective_Passage" [
    if any? mines [
      ask n-of (min (list 2 (count mines))) mines [ die ]
    ]
    set permission-factor (bound (permission-factor + 0.08) 0.10 0.97)
    set insurance-availability (bound (insurance-availability + 0.02) 0.10 1)
    set operator-caution (bound (operator-caution - 0.02) 0 1)
    ask iran-agent [
      set economic-buffer (bound (economic-buffer + 0.02) 0 1)
    ]
  ]

  if act = "Sustain_Economic_War" [
    set permission-factor (bound (permission-factor - 0.04) 0.10 0.97)
    set insurance-availability (bound (insurance-availability - 0.03) 0.10 1)
    set operator-caution (bound (operator-caution + 0.08) 0 1)
    set insurer-memory (bound (insurer-memory + 0.06) 0 1)
    set operator-memory (bound (operator-memory + 0.05) 0 1)
    set market-memory (bound (market-memory + 0.08) 0 1)
    ask iran-agent [
      set asymmetric-assets (bound (asymmetric-assets - 2) 0 100)
      set economic-buffer (bound (economic-buffer + 0.01) 0 1)
    ]
  ]

  if act = "Deploy_Mines" [
    ask iran-agent [
      let n (min (list mine-batch-size (round (asymmetric-assets / 4))))
      if n > 0 [
        let open-patches patches with [ lane? and not any? mines-here ]
        if any? open-patches [
          let actual-n (min (list n (count open-patches)))
          ask n-of actual-n open-patches [
            sprout-mines 1 [
              set color red + 2
              set size 0.8
            ]
          ]
          set asymmetric-assets (bound (asymmetric-assets - (actual-n * 1.5)) 0 100)
        ]
      ]
    ]
    set permission-factor (bound (permission-factor - 0.15) 0.10 0.95)
    set market-memory (bound (market-memory + 0.10) 0 1)
  ]

  if act = "Harass_Shipping" [
    set proxy-attack-level (proxy-attack-level + 1)
    set us-casualties (bound (us-casualties + 0.02) 0 1)
    set anchorage-risk (bound (anchorage-risk + 0.08) 0 1)
    set market-memory (bound (market-memory + 0.07) 0 1)
    ask iran-agent [ set asymmetric-assets (bound (asymmetric-assets - 5) 0 100) ]
    set permission-factor (bound (permission-factor - 0.12) 0.10 0.95)
  ]

  if act = "Proxy_Attack" [
    set proxy-attack-level (proxy-attack-level + 1)
    set us-casualties (bound (us-casualties + 0.04) 0 1)
    set anchorage-risk (bound (anchorage-risk + 0.05) 0 1)
    set market-memory (bound (market-memory + 0.05) 0 1)
    ask iran-agent [ set asymmetric-assets (bound (asymmetric-assets - 4) 0 100) ]
    set permission-factor (bound (permission-factor - 0.08) 0.10 0.95)
  ]

  if act = "Missile_Swarm" [
    set proxy-attack-level (proxy-attack-level + 2)
    set us-casualties (bound (us-casualties + 0.06) 0 1)
    set anchorage-risk (bound (anchorage-risk + 0.10) 0 1)
    set market-memory (bound (market-memory + 0.08) 0 1)
    ask iran-agent [ set asymmetric-assets (bound (asymmetric-assets - 7) 0 100) ]
    ask israel-agent [ set security-perception (bound (security-perception - 0.08) 0 1) ]
    set permission-factor (bound (permission-factor - 0.10) 0.10 0.95)
  ]
end

to update-market-state
  update-physical-throughput
  update-permission-factor
  update-gnss-reliability
  update-port-operability
  update-commercial-insurer
  update-memory-stocks
  update-insurance-market
  update-commercial-throughput
  update-recovery-factor

  set navigational-reliability
    (bound ((0.55 * gnss-reliability) + (0.45 * port-operability)) 0.15 1)

  let access-climate
    (bound ((0.38 * commercial-throughput)
      + (0.25 * navigational-reliability)
      + (0.22 * permission-factor)
      + (0.15 * (1 - market-memory))) 0.10 1)

  set strait-throughput
    (bound (physical-throughput
      * access-climate
      * (0.62 + (0.38 * recovery-factor))) 0.02 1)

  set market-panic-index
    (bound ((1 - strait-throughput)
      + ((1 - insurance-availability) * 0.30)
      + ((1 - gnss-reliability) * 0.16)
      + (regional-strike-volume * 0.14)
      + (proxy-attack-level * 0.10)
      + (market-memory * 0.22)) 0 1.8)

  let previous-oil-risk-premium oil-risk-premium
  let previous-risk-premium-peak risk-premium-peak
  let stable-access-for-market? (member? access-state ["Selective_Passage" "Escorted_Reopening" "Open_Passage"]
                                 and strait-throughput > 0.45
                                 and permission-factor > 0.40)
  let habituation-term (min list 20 (ticks-since-major-strike * 0.4))

  set risk-premium-gross-signal (((1 - strait-throughput) * 22)
                                 + (market-panic-index * 20)
                                 + (market-memory * 8))

  set risk-premium-reassurance-signal ((recovery-factor * 9)
                                       + (diplomatic-momentum * 10)
                                       + (ifelse-value (not major-strike-this-tick?) [10] [0])
                                       + (ifelse-value (strait-throughput > 0.55) [12] [0])
                                       + (ifelse-value stable-access-for-market? [8] [0])
                                       + habituation-term)
  set risk-premium-target (max list 0 (risk-premium-gross-signal - risk-premium-reassurance-signal))
  set risk-premium-gap (risk-premium-target - oil-risk-premium)
  set market-recovery-rate-current (min list 0.80 (0.20 * tau-k-rate))

  ifelse risk-premium-gap > 0
  [

    set oil-risk-premium (oil-risk-premium + (market-shock-build-up-rate * risk-premium-gap))
  ]
  [

    set oil-risk-premium (oil-risk-premium + (market-recovery-rate-current * risk-premium-gap))
  ]
  set oil-risk-premium (bound oil-risk-premium 0 120)

  if oil-risk-premium > risk-premium-peak [ set risk-premium-peak oil-risk-premium ]

  if previous-risk-premium-peak >= 25 [
    set risk-premium-post-peak-ticks (risk-premium-post-peak-ticks + 1)
    if oil-risk-premium < previous-oil-risk-premium [
      set risk-premium-decay-ticks (risk-premium-decay-ticks + 1)
    ]
  ]
  if tick-military-deescalation-window-start != -1 [
    set risk-premium-post-deescalation-ticks (risk-premium-post-deescalation-ticks + 1)
    if oil-risk-premium < previous-oil-risk-premium [
      set risk-premium-post-deescalation-decay-ticks (risk-premium-post-deescalation-decay-ticks + 1)
    ]
  ]

  set brent-crude-price (oil-fundamental-price + oil-risk-premium)

  if brent-crude-price > 70 [
    set cumulative-oil-burden (cumulative-oil-burden + (brent-crude-price - 70))
  ]

  if strait-throughput < 0.35 [
    set low-throughput-days (low-throughput-days + 1)
  ]

  recolor-lanes
end

to update-physical-throughput
  ask patches with [ lane? ] [
    set blocked? any? mines-here
    set reachable? false
  ]

  let frontier patches with [ lane? and pxcor = min-pxcor and not blocked? ]
  ask frontier [ set reachable? true ]

  while [ any? frontier ] [
    let new-frontier patches with [ lane? and not blocked? and not reachable? and any? neighbors4 with [ reachable? ] ]
    ask new-frontier [ set reachable? true ]
    set frontier new-frontier
  ]

  ifelse any? patches with [ lane? and pxcor = max-pxcor and reachable? ]
  [
    let reachable-share ((count patches with [ lane? and reachable? ]) / (count patches with [ lane? ]))
    let mine-density ((count mines) / max (list 1 (count patches with [ lane? ])))
    set physical-throughput (bound (reachable-share * (1 - (mine-density * 1.4))) 0.05 1)
  ]
  [
    set physical-throughput 0.05
  ]
end

to update-permission-factor
  if last-iran-action = "Conditional_Reopening" [
    set permission-factor (bound (permission-factor + 0.02 + (diplomatic-momentum * 0.01)) 0.10 0.98)
  ]
  if last-iran-action = "Selective_Passage" [
    set permission-factor (bound (permission-factor + 0.010 + (diplomatic-momentum * 0.008)) 0.10 0.97)
  ]
  if last-iran-action = "Hold" [
    set permission-factor (bound (permission-factor + 0.004 + (diplomatic-momentum * 0.004) - (regional-strike-volume * 0.003)) 0.10 0.97)
  ]
  if last-iran-action = "Sustain_Economic_War" [
    set permission-factor (bound (permission-factor - 0.020) 0.10 0.97)
  ]
  if last-iran-action = "Deploy_Mines" [
    set permission-factor (bound (permission-factor - 0.05) 0.10 0.97)
  ]
  if last-iran-action = "Harass_Shipping" [
    set permission-factor (bound (permission-factor - 0.035) 0.10 0.97)
  ]
  if member? last-iran-action ["Proxy_Attack" "Missile_Swarm"] [
    set permission-factor (bound (permission-factor - 0.025) 0.10 0.97)
  ]
end

to update-gnss-reliability
  let gnss-shock ((proxy-attack-level * 0.05) + (regional-strike-volume * 0.04) + (anchorage-risk * 0.03) + (operator-memory * 0.03))
  let repair-boost ((recovery-factor * 0.030) + (permission-factor * 0.012) + (diplomatic-momentum * 0.020))
  if last-iran-action = "Conditional_Reopening" [ set repair-boost (repair-boost + 0.02) ]
  set gnss-reliability (bound (gnss-reliability - gnss-shock + repair-boost) 0.15 1)
end

to update-port-operability
  let port-shock ((regional-strike-volume * 0.08) + (proxy-attack-level * 0.05) + ((1 - gnss-reliability) * 0.05))
  set anchorage-risk (bound (anchorage-risk + port-shock - (recovery-factor * 0.04)) 0 1)
  set port-operability (bound (1 - anchorage-risk - (regional-strike-volume * 0.03)) 0.15 1)
end

to update-memory-stocks
  let threat ((regional-strike-volume * 0.10)
              + (proxy-attack-level * 0.07)
              + ((1 - permission-factor) * 0.16)
              + ((1 - gnss-reliability) * 0.08)
              + ((1 - insurance-availability) * 0.06)
              + ((1 - port-operability) * 0.05))
  if last-iran-action = "Sustain_Economic_War" [ set threat (threat + 0.08) ]
  if last-iran-action = "Deploy_Mines" [ set threat (threat + 0.06) ]

  let stable-access? (member? access-state ["Selective_Passage" "Escorted_Reopening" "Open_Passage"]
                      and permission-factor > 0.40
                      and strait-throughput > 0.30)
  let reassurance ((recovery-factor * 0.07) + (diplomatic-momentum * 0.06))
  if member? last-iran-action ["Conditional_Reopening" "Selective_Passage"] [ set reassurance (reassurance + 0.06) ]
  if not major-strike-this-tick? [ set reassurance (reassurance + 0.06) ]
  if stable-access? [ set reassurance (reassurance + 0.07) ]
  if military-deescalation-window? = true [ set reassurance (reassurance + 0.05) ]

  set insurer-memory (bound (insurer-memory + (threat * 0.10 * tau-c-rate) - (reassurance * 0.18 * tau-c-rate)) 0 1)
  set operator-memory (bound (operator-memory + (threat * 0.08 * tau-c-rate) - (reassurance * 0.20 * tau-c-rate)) 0 1)
  set market-memory (bound (market-memory + (threat * 0.08 * tau-k-rate)
                            + (max list 0 ((brent-crude-price - 85) / 100) * 0.035)
                            - (reassurance * 0.16 * tau-k-rate)) 0 1)
end

to update-insurance-market
  let threat-score (((1 - permission-factor) * 0.18)
                    + ((1 - gnss-reliability) * 0.10)
                    + (regional-strike-volume * 0.05)
                    + (proxy-attack-level * 0.05)
                    + ((1 - port-operability) * 0.05)
                    + (insurer-memory * 0.08)
                    + (market-memory * 0.04))

  let stable-access? (member? access-state ["Selective_Passage" "Escorted_Reopening" "Open_Passage"]
                      and permission-factor > 0.40
                      and strait-throughput > 0.30)
  let reassurance-bonus ((recovery-factor * 0.04)
                         + (diplomatic-momentum * 0.04)
                         + (ifelse-value (member? last-iran-action ["Conditional_Reopening" "Selective_Passage"]) [0.05] [0])
                         + (ifelse-value stable-access? [0.05] [0])
                         + (ifelse-value (military-deescalation-window? = true) [0.04] [0])
                         + (ifelse-value (insurance-availability > 0.35) [0.025] [0]))

  set operator-caution
    (bound (operator-caution
            + (awrp * 0.035)
            + (threat-score * 0.09 * tau-c-rate)
            + (operator-memory * 0.035)
            - (recovery-factor * 0.14 * tau-c-rate)
            - (diplomatic-momentum * 0.06 * tau-c-rate)
            - (reassurance-bonus * 1.30 * tau-c-rate)) 0 1)
  set insurance-availability
    (bound (insurance-availability
            - (awrp * 0.035)
            - (threat-score * 0.020 * tau-c-rate)
            - (insurer-memory * 0.020)
            + (reassurance-bonus * 1.45 * tau-c-rate)) 0.10 1)
end

to update-commercial-throughput
  set commercial-throughput
    (bound ((0.28 * insurance-availability)
      + (0.27 * permission-factor)
      + (0.18 * port-operability)
      + (0.10 * gnss-reliability)
      + (0.09 * (1 - operator-caution))
      + (0.08 * (1 - market-memory))) 0.08 1)
end

to update-recovery-factor
  if member? last-iran-action ["Deploy_Mines" "Harass_Shipping" "Proxy_Attack" "Missile_Swarm"] [
    set recent-iran-escalation-streak (recent-iran-escalation-streak + 1)
    set recovery-factor (bound (recovery-factor - 0.10) 0 1)
  ]

  if last-iran-action = "Sustain_Economic_War" [
    set recent-iran-escalation-streak (recent-iran-escalation-streak + 1)
    set recovery-factor (bound (recovery-factor - 0.05) 0 1)
  ]

  if member? last-iran-action ["Conditional_Reopening" "Selective_Passage" "Hold" "None"] [
    set recent-iran-escalation-streak max (list 0 (recent-iran-escalation-streak - 1))
  ]

  if member? last-iran-action ["Conditional_Reopening" "Selective_Passage"] and regional-strike-volume = 0 and proxy-attack-level = 0 [
    set recovery-factor (bound (recovery-factor + 0.03) 0 1)
  ]

  if military-pause? and regional-strike-volume = 0 and proxy-attack-level = 0 and insurance-availability > 0.45 [
    set recovery-factor (bound (recovery-factor + 0.02) 0 1)
  ]

  if insurance-availability < 0.35 or gnss-reliability < 0.40 [
    set recovery-factor (bound (recovery-factor - 0.02) 0 1)
  ]

  if member? last-us-action ["Conventional_Strike" "Ground_Operation"] [
    set recovery-factor (bound (recovery-factor - 0.04) 0 1)
  ]

  if member? last-israel-action ["Max_Strike" "Ground_Push"] [
    set recovery-factor (bound (recovery-factor - 0.04) 0 1)
  ]
end

to recolor-lanes
  ask patches with [ lane? ] [
    ifelse blocked?
      [ set pcolor 15 ]
      [
        ifelse reachable?
          [ set pcolor 87 ]
          [ set pcolor 97 ]
      ]
  ]
  ask patches with [ water? and not lane? ] [ set pcolor 95 ]
  ask patches with [ not water? ] [ set pcolor 35 ]
end

to update-actor-states
  ask us-agent [
    set electoral-proximity (bound (electoral-proximity + 0.003) 0 1)
  ]

  ask iran-agent [

    let buffer-drain (((1 - strait-throughput) * 0.012) + (regional-strike-volume * 0.005))
    let oil-rent-gain 0
    if brent-crude-price > 90 [
      set oil-rent-gain (((brent-crude-price - 90) / 100) * 0.04)
    ]
    if military-pause? and economic-war-active? [
      set oil-rent-gain (oil-rent-gain + 0.006)
    ]
    if permission-factor > 0.55 [
      set oil-rent-gain (oil-rent-gain + 0.004)
    ]

    set economic-buffer (bound (economic-buffer - buffer-drain + oil-rent-gain) 0 1)

    let stability-drain ((regional-strike-volume * 0.010) + ((1 - economic-buffer) * 0.008))
    let stability-gain (proxy-attack-level * 0.004)
    if brent-crude-price > 95 and military-pause? [
      set stability-gain (stability-gain + 0.010)
    ]
    if regional-strike-volume = 0 and permission-factor > 0.45 [
      set stability-gain (stability-gain + 0.005)
    ]

    set regime-stability (bound (regime-stability - stability-drain + stability-gain) 0 1)
  ]

  ask israel-agent [
    let d 0
    if member? israel-observed-iran-action ["Harass_Shipping" "Proxy_Attack" "Missile_Swarm" "Deploy_Mines" "Sustain_Economic_War"] [ set d (d - 0.06) ]
    if military-degradation > 0.45 [ set d (d + 0.04) ]
    if strait-throughput > 0.45 and permission-factor > 0.55 [ set d (d + 0.02) ]
    if military-pause? and economic-war-active? [ set d (d - 0.03) ]
    set security-perception (bound (security-perception + d) 0 1)

    if israel-observed-us-action = "Pursue_Ceasefire" and member? last-israel-action ["Max_Strike" "Ground_Push"] [
      set tolerance-us-friction (bound (tolerance-us-friction - 0.03) 0 1)
    ]
  ]
end

to determine-crisis-state
  let previous-state crisis-state

  if ground-war? [
    set military-pause? false
    set military-state "Ground_War"
    set access-state (ifelse-value (strait-throughput < 0.35) ["Partial_Closure"] ["Selective_Passage"])
    set diplomacy-state "No_Talks"
    set economic-war-active? true
    set economic-war-state "War_Driven_Oil_Shock"

    ifelse accidental-war?
      [ set crisis-state "Accidental_War" ]
      [ set crisis-state "Ground_War" ]
    set resolution-tick ticks
    stop
  ]

  let deescalatory? (last-us-action = "Pursue_Ceasefire"
                     and not member? last-israel-action ["Conventional_Strike" "Max_Strike" "Ground_Push"]
                     and not member? last-iran-action ["Missile_Swarm" "Proxy_Attack"])

  if deescalatory? [
    set diplomatic-momentum (bound (diplomatic-momentum + (0.04 * tau-d-rate)) 0 1)
  ]
  if not deescalatory? [
    set diplomatic-momentum (bound (diplomatic-momentum - (0.03 * tau-d-rate)) 0 1)
  ]

  set major-action-this-tick? major-strike-this-tick?
  set low-intensity-military? false

  let any-strike-action-this-tick? (member? last-us-action ["Conventional_Strike" "Ground_Operation"]
                                    or member? last-israel-action ["Conventional_Strike" "Max_Strike" "Ground_Push"]
                                    or member? last-iran-action ["Missile_Swarm" "Proxy_Attack" "Harass_Shipping" "Deploy_Mines"])

  set military-pause? false
  if not any-strike-action-this-tick?
     and (regional-strike-volume <= 0.5)
     and (proxy-attack-level <= 0.5) [
    set military-pause? true
    set military-state "Military_Pause"
  ]
  if (not military-pause?) and (not major-action-this-tick?) [
    set military-state "Limited_Exchange"
  ]
  if major-action-this-tick? [
    set military-state "Active_Military_War"
    set military-pause? false
  ]
  set low-intensity-military? (member? military-state ["Military_Pause" "Limited_Exchange"])

  let strike-this-tick? any-strike-action-this-tick?
  let major-strike-this-tick major-action-this-tick?

  set recent-strike-history (lput (ifelse-value strike-this-tick? [1] [0]) recent-strike-history)
  if length recent-strike-history > 3 [
    set recent-strike-history (but-first recent-strike-history)
  ]
  set military-pause-window? ((sum recent-strike-history) = 0)
  if military-pause-window? and tick-military-pause-window-start = -1 [
    set tick-military-pause-window-start ticks
  ]

  set recent-major-strike-history (lput (ifelse-value major-strike-this-tick [1] [0]) recent-major-strike-history)
  if length recent-major-strike-history > 3 [
    set recent-major-strike-history (but-first recent-major-strike-history)
  ]
  set military-deescalation-window? (((sum recent-major-strike-history) = 0) and low-intensity-military?)
  if military-deescalation-window? and tick-military-deescalation-window-start = -1 [
    set tick-military-deescalation-window-start ticks
  ]

  if (strait-throughput > 0.82) and (insurance-availability > 0.78) and (permission-factor > 0.82) [
    set access-state "Open_Passage"
  ]
  if (strait-throughput > 0.58) and (insurance-availability > 0.52) and (permission-factor > 0.60) and access-state != "Open_Passage" [
    set access-state "Escorted_Reopening"
  ]
  if (permission-factor > 0.38) and (strait-throughput > 0.18) and not member? access-state ["Open_Passage" "Escorted_Reopening"] [
    set access-state "Selective_Passage"
  ]
  if not ((strait-throughput > 0.18) and (permission-factor > 0.38)) [
    set access-state "Partial_Closure"
  ]

  if (military-deescalation-window?
      and member? access-state ["Selective_Passage" "Escorted_Reopening"]
      and not major-strike-this-tick?) [
    set diplomatic-momentum (bound (diplomatic-momentum + (0.015 * tau-d-rate)) 0 1)
  ]

  if (diplomacy-state = "No_Talks"
      and military-deescalation-window?
      and member? access-state ["Selective_Passage" "Escorted_Reopening"]
      and insurance-availability > 0.40) [
    if random-float 1 < diplomacy-bridge-prob [
      set diplomatic-momentum (max list diplomatic-momentum 0.30)
      set diplomacy-bridge-events (diplomacy-bridge-events + 1)
    ]
  ]

  if diplomatic-momentum > 0.70 [
    set diplomacy-state "Fragile_Arrangement"
  ]
  if diplomatic-momentum > 0.45 and diplomatic-momentum <= 0.70 [
    set diplomacy-state "Ceasefire_Talks"
  ]
  if diplomatic-momentum > 0.20 and diplomatic-momentum <= 0.45 [
    set diplomacy-state "Backchannel_Bargaining"
  ]
  if diplomatic-momentum <= 0.20 [
    set diplomacy-state "No_Talks"
  ]

  set economic-war-active? ((brent-crude-price > 90)
                            or (insurance-availability < 0.75)
                            or (permission-factor < 0.88)
                            or (market-memory > 0.25)
                            or member? last-iran-action ["Sustain_Economic_War" "Deploy_Mines" "Harass_Shipping" "Selective_Passage"])

  if not economic-war-active? [
    set economic-war-state "No_Economic_War"
  ]
  if economic-war-active? [
    if member? last-iran-action ["Sustain_Economic_War" "Deploy_Mines" "Harass_Shipping"] or (market-memory > 0.45) [
      set economic-war-state "Prolonged_Economic_War"
    ]
    if (economic-war-state != "Prolonged_Economic_War") and ((brent-crude-price > 100) or (insurance-availability < 0.55)) [
      set economic-war-state "Oil_Price_Coercion"
    ]
    if not member? economic-war-state ["Prolonged_Economic_War" "Oil_Price_Coercion"] [
      set economic-war-state "Selective_Economic_Pressure"
    ]
  ]

  let ceasefire-ready? (military-pause?
                        and not economic-war-active?
                        and (access-state = "Open_Passage")
                        and (diplomacy-state = "Fragile_Arrangement")
                        and ([security-perception] of israel-agent > 0.66)
                        and ([regime-stability] of iran-agent > 0.25)
                        and (regional-strike-volume = 0)
                        and (proxy-attack-level = 0))

  if ceasefire-ready? [
    set ceasefire-stability-streak (ceasefire-stability-streak + 1)
  ]
  if not ceasefire-ready? [
    set ceasefire-stability-streak 0
  ]

  if ceasefire-stability-streak >= 7 [
    set ceasefire? true
    set crisis-state "Ceasefire"
    set resolution-tick ticks
    stop
  ]

  if (strait-throughput < 0.15) and (us-casualties > 0.12) and not ceasefire? [
    set cascade-streak (cascade-streak + 1)
  ]
  if not ((strait-throughput < 0.15) and (us-casualties > 0.12) and not ceasefire?) [
    set cascade-streak 0
  ]

  if cascade-streak >= 2 [
    set crisis-state "Escalation_Cascade"
    set resolution-tick ticks
    stop
  ]

  let next-state "Armed_Bargaining"

  if access-state = "Partial_Closure" [
    set next-state "Partial_Closure"
  ]

  if (next-state = "Armed_Bargaining") and (access-state = "Selective_Passage") [
    set next-state "Selective_Passage"
  ]

  if (next-state = "Armed_Bargaining") and (access-state = "Escorted_Reopening")
     and member? diplomacy-state ["Ceasefire_Talks" "Fragile_Arrangement"] [
    set next-state "Contested_Reopening"
  ]

  if (next-state = "Armed_Bargaining") and military-pause? and economic-war-active?
     and member? access-state ["Selective_Passage" "Escorted_Reopening" "Partial_Closure"]
     and (diplomatic-momentum > 0.30) [
    set next-state "Military_Pause_Economic_War"
  ]

  let awrp-half-recovery-threshold (awrp-baseline + (0.50 * (awrp-peak - awrp-baseline)))
  let commercial-score 0
  if awrp > awrp-half-recovery-threshold [ set commercial-score (commercial-score + 1) ]
  if insurance-availability < 0.50 [ set commercial-score (commercial-score + 1) ]
  if operator-caution > 0.65 [ set commercial-score (commercial-score + 1) ]
  if strait-throughput < 0.65 [ set commercial-score (commercial-score + 1) ]
  set commercial-non-normalization-score commercial-score

  let commercial-non-normalized? (commercial-score >= 2)
  let market-still-elevated? (oil-risk-premium > 10)

  let stalemate-conditions (military-deescalation-window?
                            and commercial-non-normalized?
                            and market-still-elevated?
                            and member? access-state ["Selective_Passage" "Escorted_Reopening" "Partial_Closure" "Contested_Reopening"]
                            and not ceasefire?)

  ifelse stalemate-conditions
    [ set managed-stalemate-streak (managed-stalemate-streak + 1)
      set ticks-in-ms-conditions (ticks-in-ms-conditions + 1) ]
    [ set managed-stalemate-streak 0 ]

  set managed-stalemate? (managed-stalemate-streak >= 2)
  if managed-stalemate? [
    set ever-managed-stalemate? true
    if tick-first-managed-stalemate = -1 [ set tick-first-managed-stalemate ticks ]
  ]

  if managed-stalemate? and member? next-state [
    "Military_Pause_Economic_War"
    "Selective_Passage"
    "Partial_Closure"
    "Contested_Reopening"
  ] [
    set next-state "Managed_Stalemate"
  ]

  set crisis-state next-state

  ifelse crisis-state = "Partial_Closure"
    [ set partial-closure-streak (partial-closure-streak + 1) ]
    [ set partial-closure-streak 0 ]

  ifelse crisis-state = "Selective_Passage"
    [ set selective-passage-streak (selective-passage-streak + 1) ]
    [ set selective-passage-streak 0 ]

  ifelse crisis-state = "Contested_Reopening"
    [ set contested-reopening-streak (contested-reopening-streak + 1) ]
    [ set contested-reopening-streak 0 ]

  if crisis-state != previous-state and resolution-tick = -1 [
    set resolution-tick ticks
  ]
end

to finalize-timeout-state

  if crisis-state = "Armed_Bargaining" [
    set crisis-state "Bargaining_Timeout"
  ]
  set resolution-tick ticks
end

to update-commercial-insurer

  let raw-evidence ((regional-strike-volume * 0.18)
                    + (proxy-attack-level * 0.12)
                    + ((count mines) * 0.025)
                    + ((1 - permission-factor) * 0.30)
                    + ((1 - gnss-reliability) * 0.10)
                    + ((1 - port-operability) * 0.08))

  let routine-flow (regional-strike-volume + (proxy-attack-level * 0.7))
  let selectivity-discount 0
  if selective-targeting-recognition > 0 and routine-flow > 0 [
    let saturation (routine-flow / (routine-flow + 2))
    set selectivity-discount (selective-targeting-recognition * 0.45 * saturation)
  ]
  let discounted-evidence (raw-evidence * (1 - selectivity-discount))

  let target-posterior (bound (discounted-evidence / 1.6) 0 0.95)

  let kappa-C (0.18 * tau-c-rate)
  set disruption-posterior (disruption-posterior + kappa-C * (target-posterior - disruption-posterior))

  if (regional-strike-volume = 0) and (proxy-attack-level = 0)
     and not member? last-iran-action ["Sustain_Economic_War" "Deploy_Mines"] [
    let kappa-recovery (0.06 * tau-c-rate)
    set disruption-posterior (disruption-posterior + kappa-recovery * (disruption-prior - disruption-posterior))
  ]

  set awrp (bound (awrp-baseline + disruption-posterior * 0.85) 0 1)
  if awrp > awrp-peak [ set awrp-peak awrp ]
end

to update-clock-trackers

  if military-pause? and tick-military-pause-start = -1 [
    set tick-military-pause-start ticks
  ]

  if (awrp-peak >= 0.55) and (awrp < 0.40) and (tick-awrp-recovery = -1) [
    set tick-awrp-recovery ticks
  ]

  if (risk-premium-peak >= 25) and (oil-risk-premium < 10) and (tick-price-recovery = -1) [
    set tick-price-recovery ticks
  ]

  let awrp-half-recovery-threshold (awrp-baseline + (0.50 * (awrp-peak - awrp-baseline)))
  if (not awrp-recovery-frac-fired?)
     and (awrp-peak >= 0.55)
     and (awrp <= awrp-half-recovery-threshold) [
    set tick-awrp-recovery-frac ticks
    set awrp-recovery-frac-fired? true
  ]
  if (not price-recovery-frac-fired?)
     and (risk-premium-peak >= 25)
     and (oil-risk-premium <= (0.30 * risk-premium-peak)) [
    set tick-price-recovery-frac ticks
    set price-recovery-frac-fired? true
  ]

  if (not price-recovery-frac-strict-fired?)
     and (risk-premium-peak >= 25)
     and (oil-risk-premium <= (0.50 * risk-premium-peak)) [
    set tick-price-recovery-frac-strict ticks
    set price-recovery-frac-strict-fired? true
  ]

  if (not price-recovery-20pct-fired?)
     and (risk-premium-peak >= 25)
     and (oil-risk-premium <= (0.80 * risk-premium-peak)) [
    set tick-price-recovery-20pct ticks
    set price-recovery-20pct-fired? true
  ]
end

to-report perceived-action [actual-action target-role]
  if actual-action = "None" [ report actual-action ]
  if random-float 1 >= observation-error-rate [ report actual-action ]

  let alternatives remove actual-action (action-set-of target-role)
  if empty? alternatives [ report actual-action ]
  report one-of alternatives
end

to-report action-set-of [role-name]
  if role-name = "US" [ report ["Pursue_Ceasefire" "Hold" "Deploy_Carrier_Group" "Conventional_Strike" "Ground_Operation"] ]
  if role-name = "Iran" [ report ["Conditional_Reopening" "Selective_Passage" "Sustain_Economic_War" "Hold" "Deploy_Mines" "Harass_Shipping" "Proxy_Attack" "Missile_Swarm"] ]
  if role-name = "Israel" [ report ["Hold" "Conventional_Strike" "Max_Strike" "Ground_Push"] ]
  report []
end

to-report bayes-update [prior p-e-given-h p-e-given-not-h]
  let numerator (p-e-given-h * prior)
  let denominator (numerator + (p-e-given-not-h * (1 - prior)))
  if denominator = 0 [ report prior ]
  report (numerator / denominator)
end

to-report bound [x lo hi]
  report max (list lo (min (list hi x)))
end

to-report us-agent
  report one-of state-actors with [ role = "US" ]
end

to-report iran-agent
  report one-of state-actors with [ role = "Iran" ]
end

to-report israel-agent
  report one-of state-actors with [ role = "Israel" ]
end

to-report outcome-partial-closure
  report ifelse-value (crisis-state = "Partial_Closure") [1] [0]
end

to-report outcome-selective-passage
  report ifelse-value (crisis-state = "Selective_Passage") [1] [0]
end

to-report outcome-contested-reopening
  report ifelse-value (crisis-state = "Contested_Reopening") [1] [0]
end

to-report outcome-armed-bargaining
  report ifelse-value (crisis-state = "Armed_Bargaining") [1] [0]
end
to-report outcome-military-pause-economic-war
  report ifelse-value (crisis-state = "Military_Pause_Economic_War") [1] [0]
end

to-report current-crisis-fit
  let target-throughput 0.40
  let target-price 102
  let target-insurance 0.55
  let target-gnss 0.55
  let target-permission 0.60
  let target-diplomacy 0.50

  let gap 0
  set gap (gap + (abs (strait-throughput - target-throughput) * 28))
  set gap (gap + (abs (brent-crude-price - target-price) * 0.38))
  set gap (gap + (abs (insurance-availability - target-insurance) * 16))
  set gap (gap + (abs (gnss-reliability - target-gnss) * 14))
  set gap (gap + (abs (permission-factor - target-permission) * 14))
  set gap (gap + (abs (diplomatic-momentum - target-diplomacy) * 10))

  if military-state = "Military_Pause" and economic-war-active? [ set gap (gap - 10) ]
  if crisis-state = "Military_Pause_Economic_War" [ set gap (gap - 16) ]
  if economic-war-state = "Prolonged_Economic_War" [ set gap (gap - 8) ]
  if access-state = "Selective_Passage" [ set gap (gap - 8) ]
  if access-state = "Partial_Closure" [ set gap (gap - 6) ]
  if crisis-state = "Contested_Reopening" [ set gap (gap - 10) ]
  if crisis-state = "Ceasefire" [ set gap (gap + 6) ]
  if crisis-state = "Accidental_War" [ set gap (gap + 10) ]
  if crisis-state = "Ground_War" [ set gap (gap + 14) ]
  if crisis-state = "Escalation_Cascade" [ set gap (gap + 12) ]

  report (- gap)
end

to-report calibration-score

  let score current-crisis-fit

  if crisis-state = "Military_Pause_Economic_War" [ set score (score + 10) ]
  if crisis-state = "Contested_Reopening" [ set score (score + 8) ]
  if crisis-state = "Selective_Passage" [ set score (score + 5) ]
  if crisis-state = "Partial_Closure" [ set score (score + 2) ]
  if crisis-state = "Ceasefire" [ set score (score - 2) ]
  if crisis-state = "Accidental_War" [ set score (score - 8) ]
  if crisis-state = "Ground_War" [ set score (score - 18) ]
  if crisis-state = "Escalation_Cascade" [ set score (score - 10) ]

  if military-state = "Military_Pause" and economic-war-active? [ set score (score + 6) ]
  if economic-war-state = "Prolonged_Economic_War" [ set score (score + 4) ]
  if access-state = "Selective_Passage" [ set score (score + 4) ]

  set score (score + (10 * contested-reopening-share))
  set score (score + (7 * selective-passage-share))
  set score (score + (3 * partial-closure-share))

  if ever-contested-reopening? [ set score (score + 2) ]
  if ever-selective-passage? [ set score (score + 1.5) ]

  report score
end

