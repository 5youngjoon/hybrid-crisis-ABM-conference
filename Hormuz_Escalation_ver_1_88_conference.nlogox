to-report tau-c-over-tau-m
  if tau-c-rate <= 0 [ report 999 ]
  report (tau-m-rate / tau-c-rate)
end

to-report tau-k-over-tau-m
  if tau-k-rate <= 0 [ report 999 ]
  report (tau-m-rate / tau-k-rate)
end

to-report tau-d-over-tau-m
  if tau-d-rate <= 0 [ report 999 ]
  report (tau-m-rate / tau-d-rate)
end

to-report awrp-recovery-lag
  if tick-military-pause-start = -1 [ report -1 ]
  if tick-awrp-recovery = -1 [ report -1 ]
  report (tick-awrp-recovery - tick-military-pause-start)
end

to-report price-recovery-lag
  if tick-military-pause-start = -1 [ report -1 ]
  if tick-price-recovery = -1 [ report -1 ]
  report (tick-price-recovery - tick-military-pause-start)
end

to-report outcome-managed-stalemate
  report ifelse-value (crisis-state = "Managed_Stalemate") [1] [0]
end

to-report ever-managed-stalemate

  report ifelse-value ever-managed-stalemate? [1] [0]
end

to-report insurance-floor-hit
  report ifelse-value (insurance-availability <= 0.11) [1] [0]
end

to-report operator-caution-ceiling-hit
  report ifelse-value (operator-caution >= 0.99) [1] [0]
end

to-report awrp-ceiling-hit
  report ifelse-value (awrp >= 0.95) [1] [0]
end

to-report risk-premium-high-hit

  report ifelse-value (oil-risk-premium >= 50) [1] [0]
end

to-report tau-c-leads-tau-m?
  if tick-awrp-recovery = -1 [ report false ]
  if tick-military-pause-start = -1 [ report false ]
  report (tick-awrp-recovery < tick-military-pause-start)
end

to-report outcome-tau-c-leads
  report ifelse-value tau-c-leads-tau-m? [1] [0]
end

to-report major-strike-this-tick?

  report (member? last-us-action ["Conventional_Strike" "Ground_Operation"]
          or member? last-israel-action ["Conventional_Strike" "Max_Strike" "Ground_Push"]
          or member? last-iran-action ["Missile_Swarm"])
end

to-report major-action-this-tick-flag
  report ifelse-value (major-action-this-tick? = true) [1] [0]
end

to-report low-intensity-military-flag
  report ifelse-value (low-intensity-military? = true) [1] [0]
end

to-report military-pause-window-flag
  report ifelse-value military-pause-window? [1] [0]
end

to-report ms-share
  if ticks <= 0 [ report 0 ]
  report (ticks-in-ms-conditions / ticks)
end

to-report ms-condition-this-tick

  let deescalated? (military-deescalation-window? = true)
  let c (deescalated?
         and (commercial-non-normalization-score >= 2)
         and (oil-risk-premium > 10)
         and member? access-state ["Selective_Passage" "Escorted_Reopening" "Partial_Closure" "Contested_Reopening"]
         and not ceasefire?)
  report ifelse-value c [1] [0]
end

to-report military-deescalation-window-flag
  report ifelse-value (military-deescalation-window? = true) [1] [0]
end

to-report awrp-recovery-lag-frac
  if tick-military-pause-start = -1 [ report -1 ]
  if tick-awrp-recovery-frac = -1 [ report -1 ]
  report (tick-awrp-recovery-frac - tick-military-pause-start)
end

to-report price-recovery-lag-frac
  if tick-military-pause-start = -1 [ report -1 ]
  if tick-price-recovery-frac = -1 [ report -1 ]
  report (tick-price-recovery-frac - tick-military-pause-start)
end

to-report tau-c-leads-tau-m-frac?
  if tick-awrp-recovery-frac = -1 [ report false ]
  if tick-military-pause-start = -1 [ report false ]
  report (tick-awrp-recovery-frac < tick-military-pause-start)
end

to-report outcome-tau-c-leads-frac
  report ifelse-value tau-c-leads-tau-m-frac? [1] [0]
end

to-report awrp-recovery-lag-frac-window
  if tick-military-pause-window-start = -1 [ report -1 ]
  if tick-awrp-recovery-frac = -1 [ report -1 ]
  report (tick-awrp-recovery-frac - tick-military-pause-window-start)
end

to-report price-recovery-lag-frac-window
  if tick-military-pause-window-start = -1 [ report -1 ]
  if tick-price-recovery-frac = -1 [ report -1 ]
  report (tick-price-recovery-frac - tick-military-pause-window-start)
end

to-report tau-c-leads-tau-m-frac-window?
  if tick-awrp-recovery-frac = -1 [ report false ]
  if tick-military-pause-window-start = -1 [ report false ]
  report (tick-awrp-recovery-frac < tick-military-pause-window-start)
end

to-report outcome-tau-c-leads-frac-window
  report ifelse-value tau-c-leads-tau-m-frac-window? [1] [0]
end

to-report awrp-recovery-lag-frac-deescalation
  if tick-military-deescalation-window-start = -1 [ report -1 ]
  if tick-awrp-recovery-frac = -1 [ report -1 ]
  report (tick-awrp-recovery-frac - tick-military-deescalation-window-start)
end

to-report price-recovery-lag-frac-deescalation
  if tick-military-deescalation-window-start = -1 [ report -1 ]
  if tick-price-recovery-frac = -1 [ report -1 ]
  report (tick-price-recovery-frac - tick-military-deescalation-window-start)
end

to-report tau-c-leads-tau-m-frac-deescalation?
  if tick-awrp-recovery-frac = -1 [ report false ]
  if tick-military-deescalation-window-start = -1 [ report false ]
  report (tick-awrp-recovery-frac < tick-military-deescalation-window-start)
end

to-report outcome-tau-c-leads-frac-deescalation
  report ifelse-value tau-c-leads-tau-m-frac-deescalation? [1] [0]
end

to-report awrp-frac-recovery-threshold
  report (awrp-baseline + (0.50 * (awrp-peak - awrp-baseline)))
end

to-report ticks-since-major-strike-flag
  report ticks-since-major-strike
end

to-report price-recovery-lag-frac-strict
  if tick-military-deescalation-window-start = -1 [ report -1 ]
  if tick-price-recovery-frac-strict = -1 [ report -1 ]
  report (tick-price-recovery-frac-strict - tick-military-deescalation-window-start)
end

to-report price-recovery-strict-fired
  report ifelse-value price-recovery-frac-strict-fired? [1] [0]
end

to-report price-recovery-fired
  report ifelse-value price-recovery-frac-fired? [1] [0]
end

to-report price-recovery-20pct-fired
  report ifelse-value price-recovery-20pct-fired? [1] [0]
end

to-report price-recovery-lag-20pct-deescalation
  if tick-military-deescalation-window-start = -1 [ report -1 ]
  if tick-price-recovery-20pct = -1 [ report -1 ]
  report (tick-price-recovery-20pct - tick-military-deescalation-window-start)
end

to-report risk-premium-decay-share
  if risk-premium-post-peak-ticks <= 0 [ report 0 ]
  report (risk-premium-decay-ticks / risk-premium-post-peak-ticks)
end

to-report risk-premium-post-deescalation-decay-share
  if risk-premium-post-deescalation-ticks <= 0 [ report 0 ]
  report (risk-premium-post-deescalation-decay-ticks / risk-premium-post-deescalation-ticks)
end

to-report risk-premium-normalized-recovery
  if risk-premium-peak <= 0 [ report 0 ]
  report (bound ((risk-premium-peak - oil-risk-premium) / risk-premium-peak) 0 1)
end

to-report ms-duration
  report ticks-in-ms-conditions
end

to-report first-managed-stalemate-tick
  report tick-first-managed-stalemate
end
]]></code>
